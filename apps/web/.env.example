POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=prive_admin
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

CORS_ORIGIN=http://localhost:3001

# Defaults below match docker-compose.dev.yml MinIO.
# For Cloudflare R2: R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com, R2_FORCE_PATH_STYLE=false
# For AWS S3: R2_ENDPOINT=https://s3.<region>.amazonaws.com, R2_FORCE_PATH_STYLE=false
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=prive-admin
R2_FORCE_PATH_STYLE=true
