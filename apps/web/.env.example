POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=prive_admin
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

CORS_ORIGIN=http://localhost:3001

# Defaults below match docker-compose.dev.yml MinIO. Replace with Cloudflare R2 values in production.
R2_TOKEN_VALUE=local
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=prive-admin-backup
# Optional: override S3 endpoint for local dev (MinIO). Leave unset in production to use Cloudflare R2.
R2_ENDPOINT=http://localhost:9000
