# Source for `op inject -i .env.example -o .env --force` (run automatically by `bun run dev`).
# Requires 1Password CLI: `brew install 1password-cli` then `op signin`.

POSTGRES_USER={{ op://SensePro-DEV/prive-admin PROD/POSTGRES_USER }}
POSTGRES_PASSWORD={{ op://SensePro-DEV/prive-admin PROD/POSTGRES_PASSWORD }}
POSTGRES_DB={{ op://SensePro-DEV/prive-admin PROD/POSTGRES_DB }}
DATABASE_URL={{ op://SensePro-DEV/prive-admin PROD/DATABASE_URL }}

BETTER_AUTH_SECRET={{ op://SensePro-DEV/prive-admin PROD/BETTER_AUTH_SECRET }}
BETTER_AUTH_URL={{ op://SensePro-DEV/prive-admin PROD/BETTER_AUTH_URL }}
NEXT_PUBLIC_APP_URL={{ op://SensePro-DEV/prive-admin PROD/NEXT_PUBLIC_APP_URL }}

CORS_ORIGIN=http://localhost:3001

# Not in 1Password yet — fill in real values when wiring R2.
R2_TOKEN_VALUE=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=prive-admin
