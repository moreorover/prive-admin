POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=prive_admin
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

CORS_ORIGIN=http://localhost:3001

R2_TOKEN_VALUE=replace_me
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET_NAME=prive-replace_me
# Optional: override S3 endpoint for local dev (e.g. MinIO from docker-compose.dev.yml).
# Leave unset in production to use Cloudflare R2.
