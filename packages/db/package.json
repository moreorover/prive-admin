{
  "name": "@prive-admin-tanstack/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "test": "vp test run",
    "test:watch": "vp test"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@prive-admin-tanstack/env": "workspace:*",
    "dotenv": "catalog:",
    "dotenv-expand": "^13.0.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@prive-admin-tanstack/config": "workspace:*",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
