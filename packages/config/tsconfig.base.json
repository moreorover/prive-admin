{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@prive-admin-tanstack/api": ["../api/src/index.ts"],
      "@prive-admin-tanstack/api/*": ["../api/src/*"],
      "@prive-admin-tanstack/application": ["../application/src/index.ts"],
      "@prive-admin-tanstack/application/*": ["../application/src/*"],
      "@prive-admin-tanstack/db": ["../db/src/index.ts"],
      "@prive-admin-tanstack/db/*": ["../db/src/*"]
    },
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"],
    "moduleResolution": "bundler"
  }
}
