{
  "name": "prive-admin-tanstack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.3.1",
      "zod": "^4.3.6",
      "@types/node": "^25.5.0",
      "lucide-react": "^1.7.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.2.2",
      "better-auth": "1.5.5",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "db:push": "turbo run db:push -F @prive-admin-tanstack/db",
    "db:studio": "turbo run db:studio -F @prive-admin-tanstack/db",
    "db:generate": "turbo run db:generate -F @prive-admin-tanstack/db",
    "db:migrate": "turbo run db:migrate -F @prive-admin-tanstack/db",
    "db:start": "turbo run db:start -F @prive-admin-tanstack/db",
    "db:watch": "turbo run db:watch -F @prive-admin-tanstack/db",
    "db:stop": "turbo run db:stop -F @prive-admin-tanstack/db",
    "db:down": "turbo run db:down -F @prive-admin-tanstack/db",
    "check": "oxlint && oxfmt --write"
  },
  "devDependencies": {
    "@prive-admin-tanstack/config": "workspace:*",
    "@prive-admin-tanstack/env": "workspace:*",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "zod": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
