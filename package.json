{
  "name": "prive-admin-tanstack",
  "version": "0.10.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@types/node": "^25.9.3",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "better-auth": "^1.6.18",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "vite-plus": "0.2.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vp run -r --parallel dev",
    "build": "vp run -r build",
    "check-types": "vp run -r check-types",
    "dev:web": "vp run --filter web dev",
    "db:push": "vp run --filter @prive-admin-tanstack/db db:push",
    "db:studio": "vp run --filter @prive-admin-tanstack/db db:studio",
    "db:generate": "vp run --filter @prive-admin-tanstack/db db:generate",
    "db:migrate": "vp run --filter @prive-admin-tanstack/db db:migrate",
    "compose:up": "docker compose -f docker-compose.dev.yml up -d",
    "compose:watch": "docker compose -f docker-compose.dev.yml up",
    "compose:stop": "docker compose -f docker-compose.dev.yml stop",
    "compose:down": "docker compose -f docker-compose.dev.yml down",
    "check": "vp lint && vp fmt --write",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@prive-admin-tanstack/config": "workspace:*",
    "@types/node": "catalog:",
    "knip": "^6.16.1",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
