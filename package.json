{
  "name": "prive-admin-tanstack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.3.1",
      "zod": "^4.3.6",
      "@types/node": "^25.5.0",
      "lucide-react": "^1.7.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.2.2",
      "better-auth": "1.5.5",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @prive-admin-tanstack/db db:push",
    "db:studio": "turbo -F @prive-admin-tanstack/db db:studio",
    "db:generate": "turbo -F @prive-admin-tanstack/db db:generate",
    "db:migrate": "turbo -F @prive-admin-tanstack/db db:migrate",
    "db:start": "turbo -F @prive-admin-tanstack/db db:start",
    "db:watch": "turbo -F @prive-admin-tanstack/db db:watch",
    "db:stop": "turbo -F @prive-admin-tanstack/db db:stop",
    "db:down": "turbo -F @prive-admin-tanstack/db db:down",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@prive-admin-tanstack/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@prive-admin-tanstack/config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11"
}
