{
  "name": "prive-admin-tanstack",
  "version": "0.4.1",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@types/node": "^25.6.2",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "better-auth": "1.5.5",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "db:push": "turbo run db:push -F @prive-admin-tanstack/db",
    "db:studio": "turbo run db:studio -F @prive-admin-tanstack/db",
    "db:generate": "turbo run db:generate -F @prive-admin-tanstack/db",
    "db:migrate": "turbo run db:migrate -F @prive-admin-tanstack/db",
    "compose:up": "docker compose -f docker-compose.dev.yml up -d",
    "compose:watch": "docker compose -f docker-compose.dev.yml up",
    "compose:stop": "docker compose -f docker-compose.dev.yml stop",
    "compose:down": "docker compose -f docker-compose.dev.yml down",
    "check": "oxlint && oxfmt --write"
  },
  "devDependencies": {
    "@prive-admin-tanstack/config": "workspace:*",
    "@prive-admin-tanstack/env": "workspace:*",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "zod": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
